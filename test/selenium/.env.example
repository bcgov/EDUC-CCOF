# CCOF Selenium Test Environment Variables
# Copy this file to .env and update with your actual values

# CRM Environment URLs
QA_CRM_URL=https://mychildcareservicestest.crm3.dynamics.com/
UAT_CRM_URL=https://mychildcareservicesuat.crm3.dynamics.com/

# Authentication Credentials
CRM_USERNAME=your-username@gov.bc.ca
CRM_PASSWORD=your-secure-password

# Test Configuration
BROWSER=chrome
TEST_SUITE=TestLoginSuite.xml
ENVIRONMENT=qa

# Optional: Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Docker Configuration
COMPOSE_PROJECT_NAME=ccof-selenium

# Grid Configuration (for Selenium Grid)
GRID_MAX_SESSION=4
GRID_TIMEOUT=300
NODE_MAX_INSTANCES=2